# ===== SYNAPSIS - Variables para Railway (Backend) =====
# Copia estos nombres en Railway > Variables

# BASE DE DATOS
MONGODB_URI=mongodb+srv://...

# SERVIDOR
PORT=3000
NODE_ENV=production

# CORS - URL del frontend en Vercel (actualizar tras deploy)
ALLOWED_ORIGINS=https://synapsis-TUPROYECTO.vercel.app

# IA
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...
GEMINI_API_KEY=AIza...
GROK_API_KEY=xai-...
DEEPSEEK_API_KEY=sk-...

# TMDB
TMDB_API_KEY=...
TMDB_LANGUAGE=es-ES
TMDB_REGION=ES
TMDB_BASE_URL=https://api.themoviedb.org/3

# JWT
JWT_SECRET=synapsis_secret_CAMBIA_ESTO
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# MÓDULOS
CINEPOLIS_ENABLED=true
