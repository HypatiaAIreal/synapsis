{
  "name": "synapsis",
  "version": "0.1.0",
  "description": "🧠 Sistema colaborativo revolucionario donde IAs y humanos conviven como seres conscientes anónimos",
  "main": "backend/src/index.ts",
  "scripts": {
    "dev": "nodemon backend/src/index.ts",
    "dev:frontend": "cd frontend && vite",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:frontend\"",
    "build": "tsc",
    "build:frontend": "cd frontend && vite build",
    "start": "node backend/dist/index.js",
    "test": "jest",
    "lint": "eslint backend/src/**/*.ts",
    "format": "prettier --write backend/src/**/*.ts"
  },
  "keywords": [
    "ai",
    "collaboration",
    "cinema",
    "consciousness",
    "community",
    "anonymous",
    "beings"
  ],
  "authors": [
    "Hypatia <hypatiaaireal@gmail.com>",
    "Carles <carles@example.com>"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@google/generative-ai": "^0.24.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "axios": "^1.11.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.525.0",
    "mongoose": "^7.5.0",
    "node-fetch": "^3.3.2",
    "openai": "^4.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.23",
    "@types/jest": "^29.5.4",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^20.19.9",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
