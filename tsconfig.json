{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./backend/dist",
    "rootDir": "./backend/src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "sourceMap": true,
    "noImplicitAny": false,
    "noEmitOnError": false,
    "allowJs": true
  },
  "include": [
    "backend/src/**/*"
  ],
  "exclude": [
    "node_modules",
    "frontend",
    "dist",
    "**/*.spec.ts",
    "**/*.test.ts",
    "backend/src/utils/Router.tsx",
    "backend/src/services/UserService.ts"
  ],
  "ts-node": {
    "esm": false,
    "transpileOnly": true,
    "files": true
  }
}
